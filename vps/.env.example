# docs/31 §5.1 — VPS 專用金鑰模板。
# 複製為 vps/.env 後填值;.env 已被 .gitignore 涵蓋,絕不 commit、絕不進 GitHub secrets。

# Cloudflare API token(v3 資料層:wrangler deploy 上傳 JSON 資產用)
# 權限只給:Account / Workers Scripts: Edit + Zone / Workers Routes: Edit(zone: techtrever.com)
# ——動不了 Pages/DNS/帳戶;VPS 永不持有 Pages 部署 token(docs/31 §5.1)
# 取得:Cloudflare Dashboard → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# 備份第二份(Google Drive)走 rclone gdrive remote,OAuth token 存 rclone.conf,不在本檔

# ntfy 告警主題(同 vps_backfill_plan.md Step 0 選的那個長字串)
NTFY=

# FinMind token(deep-backfill / compute-adjustments 用;WP-B4 時由 GitHub secret 遷入)
RADAR_FINMIND_TOKEN=
