# docs/31 §5.1 — VPS 專用金鑰模板。
# 複製為 vps/.env 後填值;.env 已被 .gitignore 涵蓋,絕不 commit、絕不進 GitHub secrets。

# R2(單一 API token,權限:Object Read & Write,範圍涵蓋兩顆 bucket:
#     trever-radar-data(站台 JSON)+ trever-radar-backup(DB 週快照))
# 取得:Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ntfy 告警主題(同 vps_backfill_plan.md Step 0 選的那個長字串)
NTFY=

# FinMind token(deep-backfill / compute-adjustments 用;WP-B4 時由 GitHub secret 遷入)
RADAR_FINMIND_TOKEN=
